    <Grid RowDefinitions="*,Auto" ColumnDefinitions="Auto,*">
        <PathIcon Name="Image" Grid.Column="0" Grid.Row="0" Width="48" Height="48" Margin="0, 0, 5, 0"></PathIcon>
