<UserControl x:Class="EgoPssgEditor.Views.DuplicateTextureView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:EgoPssgEditor.ViewModels"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="150"
             x:DataType="viewModels:DuplicateTextureViewModel">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 0 ">
            <Button Margin="0 0 10 0" IsDefault="True" Command="{Binding OkCommand}">Ok</Button>
            <Button IsCancel="True" Command="{Binding CancelCommand}">Cancel</Button>
        </StackPanel>
        <StackPanel>
            <Label>Texture Name</Label>
            <TextBox Text="{Binding TextureName}"></TextBox>
        </StackPanel>
    </DockPanel>
</UserControl>