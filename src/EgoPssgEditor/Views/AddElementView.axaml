<UserControl x:Class="EgoPssgEditor.Views.AddElementView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:EgoPssgEditor.ViewModels"
             mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="200"
             x:DataType="viewModels:AddElementViewModel">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 0 ">
            <Button Margin="0 0 10 0" IsDefault="True" Command="{Binding OkCommand}">Ok</Button>
            <Button IsCancel="True" Command="{Binding CancelCommand}">Cancel</Button>
        </StackPanel>
        <StackPanel>
            <Label>Element Name</Label>
            <ComboBox IsEditable="True" MinWidth="200"
                      ItemsSource="{Binding Elements}"
                      Text="{Binding ElementName}"></ComboBox>
        </StackPanel>
    </DockPanel>
</UserControl>